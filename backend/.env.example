PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
#
# LOCAL DEVELOPMENT (local PostgreSQL)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/lms_db
#
# SUPABASE (recommended for hosted environments)
# Obtain these values from your Supabase project → Settings → Database.
#
# Option A — Transaction Pooler (recommended, works on serverless/Render/Railway):
# DATABASE_URL=postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Option B — Session Pooler:
# DATABASE_URL=postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# Option C — Direct connection (use only when you need long-lived connections):
# DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/lms_db

# ─── Supabase JS client ────────────────────────────────────────────────────────
# Required for Supabase Storage (file uploads) and other Supabase JS features.
# Find these in your Supabase project → Settings → API.
SUPABASE_URL=https://[project-id].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
