# Backend API base URL.
#
# LOCAL DEVELOPMENT (default — Vite dev-server proxy handles /api/* → localhost:5000):
# Leave this unset or set it to the proxy path:
# VITE_API_URL=/api
#
# PRODUCTION (Netlify or any static host):
# Set this to the full URL of your deployed backend, e.g.:
# VITE_API_URL=https://your-lms-backend.onrender.com/api
#
# After changing this value you must rebuild the frontend.
VITE_API_URL=
